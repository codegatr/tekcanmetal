# =====================================================
# Tekcan Metal CMS — Root .htaccess
# LiteSpeed / Apache uyumlu
# =====================================================

# UTF-8 default
AddDefaultCharset UTF-8

# Index sayfaları
DirectoryIndex index.php index.html

# Server signature kapalı
ServerSignature Off

# Options
Options -Indexes -ExecCGI
<IfModule mod_rewrite.c>
    Options +FollowSymLinks
</IfModule>

# =====================================================
# Admin sayfaları için NO-CACHE — yenilenmeme sorununu çözer
# =====================================================
<IfModule mod_headers.c>
    <FilesMatch "^(admin/|.*\.(php))">
        # PHP sayfaları cache'lenmesin
    </FilesMatch>
</IfModule>

# /admin/ altındaki her şey cache'lenmesin
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteCond %{REQUEST_URI} ^/admin/
    RewriteRule .* - [E=NO_CACHE:1]
</IfModule>
<IfModule mod_headers.c>
    Header set Cache-Control "no-cache, no-store, must-revalidate" env=NO_CACHE
    Header set Pragma "no-cache" env=NO_CACHE
    Header set Expires "0" env=NO_CACHE
</IfModule>

# LiteSpeed Cache — admin'i hariç tut
<IfModule LiteSpeed>
    RewriteEngine On
    RewriteCond %{REQUEST_URI} ^/admin/ [OR]
    RewriteCond %{REQUEST_URI} \.php$
    RewriteRule .* - [E=Cache-Control:no-cache]
</IfModule>

# =====================================================
# Hassas dosyaları kapat
# =====================================================
<FilesMatch "^(config\.php|composer\.(json|lock)|package(-lock)?\.json|\.env|\.gitignore|\.gitattributes|README\.md|LICENSE|manifest\.json)$">
    Require all denied
</FilesMatch>

# Yedek dosyaları
<FilesMatch "\.(bak|sql|swp|swo|log|orig|save|old|inc)$">
    Require all denied
</FilesMatch>

# .git ve gizli dosyalar
RedirectMatch 404 /\.git
RedirectMatch 404 /\.svn
RedirectMatch 404 /\.htaccess$
RedirectMatch 404 /\.htpasswd$

# =====================================================
# Güvenlik başlıkları
# =====================================================
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-XSS-Protection "1; mode=block"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    Header set Permissions-Policy "geolocation=(), microphone=(), camera=()"
    # PHP version banner kaldır
    Header unset X-Powered-By
</IfModule>

# =====================================================
# GZIP / Sıkıştırma
# =====================================================
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/plain
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/xml
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE text/javascript
    AddOutputFilterByType DEFLATE application/xml
    AddOutputFilterByType DEFLATE application/xhtml+xml
    AddOutputFilterByType DEFLATE application/rss+xml
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/x-javascript
    AddOutputFilterByType DEFLATE application/json
    AddOutputFilterByType DEFLATE application/x-font-ttf
    AddOutputFilterByType DEFLATE image/svg+xml
    AddOutputFilterByType DEFLATE font/opentype
</IfModule>

# =====================================================
# Tarayıcı önbelleği
# =====================================================
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresDefault                              "access plus 1 month"

    # Görseller
    ExpiresByType image/jpeg                    "access plus 6 months"
    ExpiresByType image/png                     "access plus 6 months"
    ExpiresByType image/gif                     "access plus 6 months"
    ExpiresByType image/webp                    "access plus 6 months"
    ExpiresByType image/svg+xml                 "access plus 6 months"
    ExpiresByType image/x-icon                  "access plus 1 year"

    # Fontlar
    ExpiresByType font/woff                     "access plus 1 year"
    ExpiresByType font/woff2                    "access plus 1 year"
    ExpiresByType application/font-woff         "access plus 1 year"
    ExpiresByType application/font-woff2        "access plus 1 year"
    ExpiresByType application/x-font-ttf        "access plus 1 year"

    # CSS / JS
    ExpiresByType text/css                      "access plus 1 month"
    ExpiresByType text/javascript               "access plus 1 month"
    ExpiresByType application/javascript        "access plus 1 month"
    ExpiresByType application/x-javascript      "access plus 1 month"

    # HTML / XML
    ExpiresByType text/html                     "access plus 1 hour"
    ExpiresByType application/xml               "access plus 1 hour"
    ExpiresByType application/xhtml+xml         "access plus 1 hour"
</IfModule>

# =====================================================
# Hot-link koruması (uploads içindeki görseller için)
# =====================================================
<IfModule mod_rewrite.c>
    RewriteEngine On

    # HTTPS yönlendirme — gerekirse aç
    # RewriteCond %{HTTPS} off
    # RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # WWW olmadan tek sürüm — gerekirse aç (settings'a göre yap)
    # RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
    # RewriteRule ^(.*)$ https://%1/$1 [L,R=301]

    # Hot-link KORUMA: DEVRE DIŞI (v1.0.29)
    # Daha önceki kural Cloudflare proxy + bazı tarayıcı senaryolarında
    # legitimate istekleri 403 ile engelliyordu (uploads/products/*.jpg).
    # Hot-link koruması artık Cloudflare WAF veya başka katmanda yapılmalı.
    # Aşağıdaki satırlar yorumda — gerekirse ileride aktif edilir.
    #
    # RewriteCond %{REQUEST_URI} ^/uploads/ [NC]
    # RewriteCond %{HTTP_REFERER} !^$
    # RewriteCond %{HTTP_REFERER} !^https?://(www\.)?v2\.tekcanmetal\.com [NC]
    # RewriteCond %{HTTP_REFERER} !^https?://(www\.)?tekcanmetal\.com [NC]
    # RewriteCond %{HTTP_REFERER} !^https?://([^/]+\.)?(google|bing|yandex|facebook|twitter|linkedin|instagram|whatsapp|t)\. [NC]
    # RewriteRule \.(jpg|jpeg|png|gif|webp|svg)$ - [F,NC]

    # sitemap.xml -> sitemap.php
    RewriteRule ^sitemap\.xml$ sitemap.php [L]

    # ═══════════════════════════════════════════════════
    # i18n DİL ROUTING (v1.0.56)
    # /en/, /ar/, /ru/ prefix'lerini E=LANG ile PHP'ye geçir
    # Default dil (TR) prefix'siz çalışır
    # ═══════════════════════════════════════════════════
    RewriteRule ^(en|ar|ru)/?$                                  index.php [L,QSA,E=LANG:%1]
    RewriteRule ^(en|ar|ru)/il/([a-z0-9\-]+)/([a-z0-9\-]+)/?$  il-urun.php?il=$2&urun=$3 [L,QSA,E=LANG:%1]
    RewriteRule ^(en|ar|ru)/il/([a-z0-9\-]+)/?$                 il.php?slug=$2 [L,QSA,E=LANG:%1]
    RewriteRule ^(en|ar|ru)/ihracat/([a-z0-9\-]+)/?$            ihracat.php?slug=$2 [L,QSA,E=LANG:%1]
    RewriteRule ^(en|ar|ru)/urun/([a-z0-9\-]+)/?$               urun.php?slug=$2 [L,QSA,E=LANG:%1]
    RewriteRule ^(en|ar|ru)/kategori/([a-z0-9\-]+)/?$           kategori.php?slug=$2 [L,QSA,E=LANG:%1]
    RewriteRule ^(en|ar|ru)/hizmet/([a-z0-9\-]+)/?$             hizmet.php?slug=$2 [L,QSA,E=LANG:%1]
    RewriteRule ^(en|ar|ru)/blog/([a-z0-9\-]+)/?$               blog-detay.php?slug=$2 [L,QSA,E=LANG:%1]
    RewriteRule ^(en|ar|ru)/sayfa/([a-z0-9\-]+)/?$              sayfa.php?slug=$2 [L,QSA,E=LANG:%1]
    RewriteRule ^(en|ar|ru)/(.+\.php)$                          $2 [L,QSA,E=LANG:%1]

    # ═══════════════════════════════════════════════════
    # SEO Pretty URLs (Türkçe — default dil, prefix'siz)
    # /il/konya          -> il.php?slug=konya
    # /il/konya/hrp-sac  -> il-urun.php?il=konya&urun=hrp-sac
    # /ihracat/irak      -> ihracat.php?slug=irak
    # /urun/hrp-sac      -> urun.php?slug=hrp-sac
    # /kategori/sac      -> kategori.php?slug=sac
    # /hizmet/lazer-kesim -> hizmet.php?slug=lazer-kesim
    # /blog/yazi-slug    -> blog-detay.php?slug=yazi-slug
    # ═══════════════════════════════════════════════════
    RewriteRule ^il/([a-z0-9\-]+)/([a-z0-9\-]+)/?$ il-urun.php?il=$1&urun=$2 [L,QSA]
    RewriteRule ^il/([a-z0-9\-]+)/?$            il.php?slug=$1 [L,QSA]
    RewriteRule ^ihracat/([a-z0-9\-]+)/?$       ihracat.php?slug=$1 [L,QSA]
    RewriteRule ^urun/([a-z0-9\-]+)/?$          urun.php?slug=$1 [L,QSA]
    RewriteRule ^kategori/([a-z0-9\-]+)/?$      kategori.php?slug=$1 [L,QSA]
    RewriteRule ^hizmet/([a-z0-9\-]+)/?$        hizmet.php?slug=$1 [L,QSA]
    RewriteRule ^blog/([a-z0-9\-]+)/?$          blog-detay.php?slug=$1 [L,QSA]
    RewriteRule ^sayfa/([a-z0-9\-]+)/?$         sayfa.php?slug=$1 [L,QSA]

    # Mevcut dosya/klasör değilse 404.php
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} !^/api/
    RewriteCond %{REQUEST_URI} !^/admin/
    RewriteRule ^.*$ 404.php [L]
</IfModule>

# =====================================================
# Yükleme limitleri (LiteSpeed/PHP-FPM ile uyumlu)
# =====================================================
<IfModule mod_php.c>
    php_value upload_max_filesize 32M
    php_value post_max_size       40M
</IfModule>
